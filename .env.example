# Payload / MongoDB
#
# Local MongoDB:
DATABASE_URI=mongodb://127.0.0.1:27017/arkham-horror-helper
#
# Docker Compose MongoDB:
# DATABASE_URI=mongodb://mongo:27017/arkham-horror-helper

# Used by Payload to sign cookies/tokens. Replace this before sharing or deploying.
# Generate one with: openssl rand -base64 32
PAYLOAD_SECRET=replace-with-a-long-random-secret

# Used by Payload live preview links.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional: use a separate signing secret for mobile controller tokens.
# If omitted, mobile controllers use PAYLOAD_SECRET.
# CONTROLLER_SECRET=replace-with-a-different-long-random-secret

# Optional: public origin encoded into mobile controller QR links.
# Set this to your LAN or deployed URL when phones cannot open localhost.
# NEXT_PUBLIC_CONTROLLER_ORIGIN=http://192.168.1.25:3000
