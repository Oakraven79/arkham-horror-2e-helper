{
  "name": "arkham-helper",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:ancient-ones-fixture": "node scripts/generate-ancient-ones-fixture.mjs",
    "generate:locations-fixture": "node scripts/generate-locations-fixture.mjs",
    "generate:mythos-fixture": "node scripts/generate-mythos-cards-fixture.mjs",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "migrate:mythos-instances": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/migrateMythosDeckInstances.ts",
    "migrate:boxed-sets": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/migrateBoxedSets.ts",
    "seed": "pnpm run seed:boxed-sets && pnpm run seed:neighborhoods && pnpm run seed:locations && pnpm run seed:arkham-encounter-cards && pnpm run seed:other-worlds && pnpm run seed:ancient-ones && pnpm run seed:mythos-cards",
    "seed:ancient-ones": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seedAncientOnes.ts",
    "seed:ancient-ones:dry-run": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seedAncientOnes.ts -- --dry-run",
    "seed:arkham-encounter-cards": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seedArkhamEncounterCards.ts",
    "seed:arkham-encounter-cards:dry-run": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seedArkhamEncounterCards.ts -- --dry-run",
    "seed:boxed-sets": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seedBoxedSets.ts",
    "seed:boxed-sets:dry-run": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seedBoxedSets.ts -- --dry-run",
    "seed:locations": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seedLocations.ts",
    "seed:locations:dry-run": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seedLocations.ts -- --dry-run",
    "seed:mythos-cards": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seedMythosCards.ts",
    "seed:mythos-cards:dry-run": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seedMythosCards.ts -- --dry-run",
    "seed:neighborhoods": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seedNeighborhoods.ts",
    "seed:neighborhoods:dry-run": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seedNeighborhoods.ts -- --dry-run",
    "seed:other-worlds": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seedOtherWorlds.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.int.config.mts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "3.50.0",
    "@payloadcms/live-preview-react": "3.50.0",
    "@payloadcms/next": "3.50.0",
    "@payloadcms/payload-cloud": "3.50.0",
    "@payloadcms/richtext-lexical": "3.50.0",
    "@payloadcms/ui": "3.50.0",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "15.4.11",
    "payload": "3.50.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "1.54.1",
    "@storybook/addon-a11y": "^9.1.4",
    "@storybook/addon-docs": "^9.1.4",
    "@storybook/addon-onboarding": "^9.1.4",
    "@storybook/addon-vitest": "^9.1.4",
    "@storybook/nextjs-vite": "^9.1.4",
    "@testing-library/react": "16.3.0",
    "@types/node": "^22.5.4",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0",
    "@vitejs/plugin-react": "4.5.2",
    "@vitest/browser": "3.2.3",
    "@vitest/coverage-v8": "3.2.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.11",
    "eslint-plugin-storybook": "^9.1.4",
    "jsdom": "26.1.0",
    "playwright": "1.54.1",
    "playwright-core": "1.54.1",
    "prettier": "^3.4.2",
    "storybook": "^9.1.4",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.3"
  },
  "engines": {
    "node": ">=22.0.0 <26",
    "pnpm": ">=11 <12"
  }
}
